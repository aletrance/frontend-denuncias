<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Control de Plantillas — Sistema de Denuncias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 font-['Inter'] overflow-y-scroll">

    <!-- Top Bar -->
    <nav class="bg-white/5 backdrop-blur-md border-b border-white/10">
        <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <span class="text-white font-semibold text-sm">Sistema de Denuncias</span>
                </div>

                <!-- Navigation Links -->
                <div class="hidden md:flex items-center gap-4 text-sm">
                    <a href="/upload" class="text-slate-400 hover:text-white transition-colors">Subir PDF</a>
                    <a href="/denuncias" class="text-blue-400 font-medium">Plantillas</a>
                    <a href="/informes" class="text-slate-400 hover:text-white transition-colors">Informes Listos</a>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <span class="text-slate-400 text-sm hidden sm:inline">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <%= username %>
                </span>
                <form action="/logout" method="POST" class="inline">
                    <button type="submit" class="text-sm px-4 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-300 hover:bg-white/10 hover:text-white transition-all duration-200">
                        Salir
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 py-8">
        
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-white tracking-tight">Control de Plantillas</h1>
                <p class="text-slate-400 mt-1 text-sm">Administra el estado y las plantillas a aplicar en base a los datos extraídos</p>
            </div>
            <!-- Alert Container for dynamic feedback -->
            <div id="alertContainer" class="hidden transform transition-all duration-300"></div>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 shadow-2xl">
            <% if (error) { %>
                <ul class="space-y-4 mb-4" id="serverErrorList">
                    <li class="group bg-red-900/30 hover:bg-red-900/40 border border-red-500/40 rounded-xl transition-all duration-300 shadow-sm">
                        <div class="py-4 px-5 flex items-center justify-between">
                            <div class="flex items-center gap-4 min-w-0 flex-1">
                                <div class="w-10 h-10 rounded-lg bg-red-500/20 border border-red-500/30 flex flex-shrink-0 items-center justify-center">
                                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                </div>
                                <div class="min-w-0 flex flex-col">
                                    <div class="flex items-center gap-2">
                                        <p class="text-red-300 font-bold text-sm tracking-wide">ERROR EN EL SISTEMA DE PLANTILLAS</p>
                                    </div>
                                    <p class="text-red-200 text-xs mt-0.5 leading-relaxed">
                                        Origen: Servidor Backend <br>
                                        Detalle: <%= error %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </li>
                </ul>
            <% } %>

            <% if (denuncias && denuncias.length > 0) { %>
                <ul class="space-y-4" id="denunciasList">
                    <% denuncias.forEach((denuncia, index) => { %>
                        <li class="group bg-slate-800/50 hover:bg-slate-800 border border-white/10 hover:border-white/20 rounded-xl transition-all duration-300 shadow-sm" data-id="<%= denuncia.Id || denuncia.id %>">
                            <!-- Header (Click to expand) -->
                            <div class="py-4 px-5 flex items-center justify-between">
                                <!-- Left side (Info) -->
                                <div class="flex items-center gap-4 min-w-0 cursor-pointer flex-1" onclick="toggleDetails(<%= index %>)">
                                    <div class="w-10 h-10 rounded-lg bg-blue-500/10 border border-blue-500/20 flex flex-shrink-0 items-center justify-center">
                                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                        </svg>
                                    </div>
                                    <div class="min-w-0 flex flex-col">
                                        <div class="flex items-center gap-2">
                                            <p class="text-white font-medium text-sm truncate group-hover:text-blue-400 transition-colors">
                                                <%= denuncia.nombre_archivo || 'Denuncia #' + (denuncia.Id || denuncia.id) %>
                                            </p>
                                            <% if (denuncia.prioritario === true || denuncia.prioritario === 'Si' || denuncia.prioritario === 'Sí' || denuncia.prioritario === 'true') { %>
                                                <span class="px-2 py-[1px] rounded text-[10px] font-bold bg-red-500/20 text-red-400 border border-red-500/30 tracking-wider">PRIORITARIO</span>
                                            <% } %>
                                            <span class="status-badge px-2 py-[1px] rounded text-[10px] font-medium border
                                                <%= denuncia.estado && (denuncia.estado.toUpperCase() === 'COMPLETADO' || denuncia.estado.toUpperCase() === 'APROBADO') ? 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400' : 'bg-blue-500/10 border-blue-500/20 text-blue-400' %>">
                                                <%= denuncia.estado ? denuncia.estado.toUpperCase() : 'PENDIENTE' %>
                                            </span>
                                        </div>
                                        <p class="text-slate-500 text-xs mt-0.5 flex items-center gap-2">
                                            <span><%= denuncia.c_numero_expediente ? `Exp: ${denuncia.c_numero_expediente}` : 'Sin Exp' %></span>
                                            <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                                            <span><%= denuncia.fecha_ingreso ? new Date(denuncia.fecha_ingreso).toLocaleDateString() : 'Sin fecha' %></span>
                                            <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                                            <span class="truncate">Víc: <%= denuncia.v_nombre_completo || '-' %> | Den: <%= denuncia.d_nombre_completo || '-' %></span>
                                        </p>
                                    </div>
                                </div>
                                
                                <!-- Right side (Actions - Inline Edit) -->
                                <div class="flex items-center justify-end gap-3 pl-4 min-w-[280px]">
                                    
                                    <div class="flex items-center gap-2 template-value-container">
                                        <span class="template-value text-slate-300 text-sm font-medium">
                                            <%= denuncia.plantilla_aplicar ? 'Plantilla ' + denuncia.plantilla_aplicar : 'Sin Asignar' %>
                                        </span>
                                        <div class="template-select-container hidden w-full max-w-[140px]">
                                            <select class="template-select bg-slate-800 border border-white/10 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5"
                                                data-current="<%= denuncia.plantilla_aplicar %>">
                                                <option value="" disabled <%= !denuncia.plantilla_aplicar ? 'selected' : '' %>>Seleccione (1-7)</option>
                                                <% for(let i=1; i<=7; i++) { %>
                                                    <option value="<%= i %>" <%= denuncia.plantilla_aplicar == i ? 'selected' : '' %>>Plantilla <%= i %></option>
                                                <% } %>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="flex items-center">
                                        <!-- Edit Button -->
                                        <button type="button" class="btn-edit p-1.5 text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg transition-all duration-200" title="Cambiar Plantilla">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                            </svg>
                                        </button>

                                        <!-- Save Button (Hidden) -->
                                        <button type="button" class="btn-save hidden p-1.5 text-emerald-400 hover:text-white bg-emerald-500/10 hover:bg-emerald-500 border border-emerald-500/20 hover:border-emerald-500 rounded-lg transition-all duration-200" title="Guardar">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                        </button>
                                        
                                        <!-- Cancel Button (Hidden) -->
                                        <button type="button" class="btn-cancel hidden p-1.5 text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg transition-all duration-200 ml-1" title="Cancelar">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                            </svg>
                                        </button>

                                        <!-- Expand icon -->
                                        <button class="p-1 text-slate-400 hover:text-white transition-colors ml-3" title="Ver detalles extraídos" onclick="toggleDetails(<%= index %>);">
                                            <svg id="icon-<%= index %>" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Expanded Details Grid -->
                            <div id="details-<%= index %>" class="hidden border-t border-white/5 bg-black/20">
                                <div class="p-5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-sm">
                                    <% const boolTxt = (val) => (val === true || val === 'true' || val === 'Si' || val === 'Sí') ? 'Sí' : (val ? val : 'No'); %>
                                    
                                    <!-- Datos de Gestión -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            Datos de Gestión
                                        </h4>
                                        <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-xs">
                                            <span class="text-slate-400">Cat. sugerida:</span> <span class="text-slate-200 font-medium"><%= denuncia.categoria_sugerida || '-' %></span>
                                            <span class="text-slate-400">Validador:</span> <span class="text-slate-200"><%= denuncia.usuario_validador || '-' %></span>
                                            <span class="text-slate-400">F. Firma:</span> <span class="text-slate-200"><%= denuncia.fecha_firma ? new Date(denuncia.fecha_firma).toLocaleDateString() : '-' %></span>
                                            <span class="text-slate-400">ID NocoDB:</span> <span class="text-slate-200"><%= denuncia.Id || denuncia.id || '-' %></span>
                                            <span class="text-slate-400 col-span-2 block mt-1">Justificación:</span>
                                            <span class="text-slate-300 col-span-2 italic bg-white/5 p-2 rounded border border-white/5 leading-relaxed"><%= denuncia.justificacion || '-' %></span>
                                        </div>
                                    </div>

                                    <!-- Involucrados -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                            Involucrados
                                        </h4>
                                        <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-xs">
                                            <span class="text-blue-300 font-semibold col-span-2">Víctima</span>
                                            <span class="text-slate-400">Nombre:</span> <span class="text-slate-200 truncate" title="<%= denuncia.v_nombre_completo %>"><%= denuncia.v_nombre_completo || '-' %></span>
                                            <span class="text-slate-400">DNI / Tel:</span> <span class="text-slate-200"><%= denuncia.v_dni || '-' %> / <%= denuncia.v_telefono || '-' %></span>
                                            
                                            <span class="text-red-300 font-semibold col-span-2 mt-2">Denunciado/a</span>
                                            <span class="text-slate-400">Nombre:</span> <span class="text-slate-200 truncate" title="<%= denuncia.d_nombre_completo %>"><%= denuncia.d_nombre_completo || '-' %></span>
                                            <span class="text-slate-400">DNI:</span> <span class="text-slate-200"><%= denuncia.d_dni || '-' %></span>
                                            
                                            <span class="text-slate-400 col-span-2 mt-1">Vínculo: <span class="text-slate-200"><%= denuncia.vinculo_partes || '-' %></span></span>
                                        </div>
                                    </div>

                                    <!-- Detalles del Hecho -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                            El Hecho
                                        </h4>
                                        <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-xs">
                                            <span class="text-slate-400">F. Hechos:</span> <span class="text-slate-200"><%= denuncia.c_fecha_hechos ? new Date(denuncia.c_fecha_hechos).toLocaleDateString() : '-' %></span>
                                            <span class="text-slate-400">Comisaría:</span> <span class="text-slate-200"><%= denuncia.c_numero_comisaria || '-' %></span>
                                            <span class="text-slate-400">Den. Policial:</span> <span class="text-slate-200"><%= denuncia.c_numero_denuncia_policial || '-' %></span>
                                            <span class="text-slate-400">T. Violencia:</span> <span class="text-slate-200"><%= denuncia.c_tipo_violencia || '-' %></span>
                                            <span class="text-slate-400">Modalidad:</span> <span class="text-slate-200"><%= denuncia.c_modalidad_violencia || '-' %></span>
                                            <span class="text-slate-400">Antecedentes:</span> <span class="text-slate-200 font-medium <%= (denuncia.hay_antecedentes_violencia === true || denuncia.hay_antecedentes_violencia === 'Si') ? 'text-red-400' : '' %>"><%= boolTxt(denuncia.hay_antecedentes_violencia) %></span>
                                            <span class="text-slate-400 block col-span-2 mt-1">Amenazas descritas:</span>
                                            <span class="text-slate-300 col-span-2 italic bg-white/5 p-2 rounded border border-white/5"><%= denuncia.descripcion_amenazas || '-' %></span>
                                        </div>
                                    </div>

                                    <!-- Medidas Solicitadas -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            Medidas Solicitadas
                                        </h4>
                                        <ul class="text-xs space-y-2 text-slate-300">
                                            <li class="flex justify-between border-b border-white/5 pb-1"><span>Abstención de actos:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_abstencion_actos_violencia) %></span></li>
                                            <li class="flex justify-between border-b border-white/5 pb-1">
                                                <span>Prohibición acercamiento:</span> 
                                                <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_prohibicion_acercamiento) %><%= denuncia.m_distancia_metros ? ` (${denuncia.m_distancia_metros}m)` : '' %></span>
                                            </li>
                                            <li class="flex justify-between border-b border-white/5 pb-1"><span>Exclusión del hogar:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_exclusion_hogar) %></span></li>
                                            <li class="flex justify-between border-b border-white/5 pb-1"><span>Reintegro efectos:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_reintegro_efectos_personales) %></span></li>
                                            <li class="flex justify-between border-b border-white/5 pb-1"><span>Alimentos provisorios:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_alimentos_provisorios) %></span></li>
                                            <li class="flex justify-between border-b border-white/5 pb-1"><span>Botón antipánico:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_boton_antipanico) %></span></li>
                                            <li class="flex justify-between pb-1"><span>Custodia policial:</span> <span class="font-medium text-white"><%= boolTxt(denuncia.m_solicita_custodia_policial) %></span></li>
                                        </ul>
                                    </div>

                                    <!-- Triage y Clasificación -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                                            Clasificación y Triage
                                        </h4>
                                        <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-xs">
                                            <span class="text-slate-400">Activadores Triage:</span> <span class="text-slate-200 col-span-2 md:col-span-1"><%= denuncia.triage_activadores || '-' %></span>
                                            <span class="text-slate-400">Evidencia Triage:</span> <span class="text-slate-200 col-span-2 md:col-span-1"><%= denuncia.triage_evidencia || '-' %></span>
                                            <span class="text-slate-400">Criterio Clasif:</span> <span class="text-slate-200 col-span-2 md:col-span-1"><%= denuncia.clasificacion_criterio || '-' %></span>
                                            <span class="text-slate-400">Evidenc. Clasif:</span> <span class="text-slate-200 col-span-2 md:col-span-1"><%= denuncia.clasificacion_evidencia || '-' %></span>
                                            <span class="text-slate-400 col-span-2 block mt-1">Justificación Triage:</span>
                                            <span class="text-slate-300 col-span-2 italic bg-white/5 p-2 rounded border border-white/5"><%= denuncia.triage_justificacion || '-' %></span>
                                        </div>
                                    </div>

                                    <!-- Contactos e Info Extra -->
                                    <div class="space-y-3">
                                        <h4 class="text-white font-semibold flex items-center gap-2 border-b border-white/10 pb-1.5">
                                            <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                            Contactos Defensoría/Turno
                                        </h4>
                                        <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-xs">
                                            <span class="text-slate-400">Nº Defensoría:</span> <span class="text-teal-300 font-medium"><%= denuncia.defensoria_numero || '-' %></span>
                                            <span class="text-slate-400">Tel. Defensoría:</span> <span class="text-slate-200"><%= denuncia.telefonos_defensoria || '-' %></span>
                                            <span class="text-slate-400">Cel. Defensoría:</span> <span class="text-slate-200"><%= denuncia.celular_defensoria || '-' %></span>
                                            <span class="text-slate-400">Tel. Polo Mujer:</span> <span class="text-slate-200"><%= denuncia.telefono_polo_mujer || '-' %></span>
                                            <span class="text-slate-400">Turno (Tel/Cel):</span> <span class="text-slate-200"><%= denuncia.telefono_turno || '-' %> / <%= denuncia.celular_turno || '-' %></span>
                                        </div>
                                    </div>

                                    <!-- Resumen Preliminar Full Width -->
                                    <% if (denuncia.resumen_preliminar) { %>
                                    <div class="col-span-1 md:col-span-2 lg:col-span-3 space-y-2 pt-3 border-t border-white/5">
                                        <span class="text-slate-400 text-xs font-semibold flex items-center gap-2">
                                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
                                            Resumen Preliminar
                                        </span>
                                        <p class="text-slate-300 text-xs bg-white/5 p-4 rounded-lg border border-white/10 leading-relaxed whitespace-pre-wrap"><%= denuncia.resumen_preliminar %></p>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <div class="text-center py-12">
                    <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/5 flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                        </svg>
                    </div>
                    <h3 class="text-white font-medium">Bandeja Vacía</h3>
                    <p class="text-slate-400 text-sm mt-1">No se encontraron registros de plantillas.</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        // Accordion functionality
        function toggleDetails(index) {
            const details = document.getElementById('details-' + index);
            const icon = document.getElementById('icon-' + index);
            if (details.classList.contains('hidden')) {
                details.classList.remove('hidden');
                if (icon) icon.classList.add('rotate-180');
            } else {
                details.classList.add('hidden');
                if (icon) icon.classList.remove('rotate-180');
            }
        }

        // Edit functionality
        document.addEventListener('DOMContentLoaded', () => {
            const showAlert = (message, type = 'success') => {
                const container = document.getElementById('alertContainer');
                const isSuccess = type === 'success';
                const colors = isSuccess 
                    ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' 
                    : 'bg-red-500/10 border-red-500/30 text-red-400';
                
                container.innerHTML = `
                    <div class="px-4 py-2 rounded-xl text-sm border flex items-center gap-2 ${colors}">
                        <div class="w-2 h-2 rounded-full ${isSuccess ? 'bg-emerald-400' : 'bg-red-400'} animate-pulse"></div>
                        ${message}
                    </div>
                `;
                container.classList.remove('hidden');

                setTimeout(() => {
                    container.classList.add('opacity-0');
                    setTimeout(() => {
                        container.classList.add('hidden');
                        container.classList.remove('opacity-0');
                    }, 300);
                }, 4000);
            };

            // Setup row handlers
            document.querySelectorAll('#denunciasList > li').forEach(row => {
                const btnEdit = row.querySelector('.btn-edit');
                if (!btnEdit) return;

                const btnSave = row.querySelector('.btn-save');
                const btnCancel = row.querySelector('.btn-cancel');
                
                const valContainer = row.querySelector('.template-value');
                const selContainer = row.querySelector('.template-select-container');
                const selectElement = row.querySelector('.template-select');
                
                const recordId = row.dataset.id;

                const toggleEditMode = (enable) => {
                    if (enable) {
                        btnEdit.classList.add('hidden');
                        btnSave.classList.remove('hidden');
                        btnCancel.classList.remove('hidden');
                        valContainer.classList.add('hidden');
                        selContainer.classList.remove('hidden');
                        // Restore precise value, bugfix: don't default to template 1
                        if (selectElement.dataset.current) {
                            selectElement.value = selectElement.dataset.current;
                        } else {
                            selectElement.value = "";
                        }
                        selectElement.focus();
                    } else {
                        btnEdit.classList.remove('hidden');
                        btnSave.classList.add('hidden');
                        btnCancel.classList.add('hidden');
                        valContainer.classList.remove('hidden');
                        selContainer.classList.add('hidden');
                        // Reset select to original state
                        selectElement.value = selectElement.dataset.current;
                    }
                };

                btnEdit.addEventListener('click', (e) => { e.stopPropagation(); toggleEditMode(true); });
                btnCancel.addEventListener('click', (e) => { e.stopPropagation(); toggleEditMode(false); });

                btnSave.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const newValue = selectElement.value;
                    if (!newValue) {
                        showAlert('Debe seleccionar una plantilla', 'error');
                        return;
                    }

                    // Loading state
                    const originalBtnContent = btnSave.innerHTML;
                    btnSave.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
                    btnSave.disabled = true;
                    btnCancel.disabled = true;

                    try {
                        const response = await fetch(`/denuncias/${recordId}`, {
                            method: 'PATCH',
                            headers: {
                                'Content-Type': 'application/json',
                                'Accept': 'application/json'
                            },
                            body: JSON.stringify({ plantilla_aplicar: parseInt(newValue, 10) })
                        });

                        const result = await response.json();

                        if (!response.ok || !result.success) {
                            throw new Error(result.error || 'Error del servidor');
                        }

                        // Update DOM: Show the new selected template and change status to APROBADO
                        selectElement.dataset.current = newValue;
                        valContainer.innerText = 'Plantilla ' + newValue;
                        
                        // Update status badge
                        const badge = row.querySelector('.status-badge');
                        if (badge) {
                            badge.innerText = 'APROBADO';
                            badge.className = 'status-badge px-2 py-[1px] rounded text-[10px] font-medium border bg-emerald-500/10 border-emerald-500/20 text-emerald-400';
                        }

                        // Exit edit mode
                        toggleEditMode(false);
                        
                        showAlert('Plantilla actualizada y denuncia procesada', 'success');

                    } catch (error) {
                        console.error('Update error:', error);
                        // Mostrar el error como una tarjeta roja en la lista
                        const listContainer = document.getElementById('denunciasList');
                        if (listContainer) {
                            const errorCard = document.createElement('li');
                            errorCard.className = 'group bg-red-900/30 hover:bg-red-900/40 border border-red-500/40 rounded-xl transition-all duration-300 shadow-sm mb-4';
                            errorCard.innerHTML = `
                                <div class="py-4 px-5 flex items-center justify-between">
                                    <div class="flex items-center gap-4 min-w-0 flex-1">
                                        <div class="w-10 h-10 rounded-lg bg-red-500/20 border border-red-500/30 flex flex-shrink-0 items-center justify-center">
                                            <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                            </svg>
                                        </div>
                                        <div class="min-w-0 flex flex-col">
                                            <p class="text-red-300 font-bold text-sm tracking-wide">ERROR DE GUARDADO</p>
                                            <p class="text-red-200 text-xs mt-0.5 leading-relaxed">
                                                Origen: Controlador de Actualización (ID: ${recordId})<br>
                                                Detalle: ${error.message}
                                            </p>
                                        </div>
                                    </div>
                                    <button class="text-red-400 hover:text-white p-2" onclick="this.closest('li').remove()">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </button>
                                </div>
                            `;
                            listContainer.insertBefore(errorCard, listContainer.firstChild);
                        }
                    } finally {
                        btnSave.innerHTML = originalBtnContent;
                        btnSave.disabled = false;
                        btnCancel.disabled = false;
                    }
                });

                // Prevent click on select from toggling accordion
                selectElement.addEventListener('click', (e) => e.stopPropagation());
            });

            // Auto-refresh logic (Polling every 30 seconds)
            // It only refreshes if NOT in edit mode
            setInterval(() => {
                const anyInEditMode = document.querySelector('.btn-edit.hidden');
                if (!anyInEditMode) {
                    console.log('Auto-refreshing denuncias list...');
                    // Optimized: we could fetch and diff, but for now simple reload is safer
                    // to ensure consistency with the user's request "como el de informes listos"
                    location.reload();
                }
            }, 30000); 
        });
    </script>
</body>
</html>
