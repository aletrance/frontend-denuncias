<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Informes Listos — Sistema de Denuncias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 font-['Inter'] overflow-y-scroll">

    <!-- Top Bar -->
    <nav class="bg-white/5 backdrop-blur-md border-b border-white/10">
        <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <span class="text-white font-semibold text-sm">Sistema de Denuncias</span>
                </div>

                <!-- Navigation Links -->
                <div class="hidden md:flex items-center gap-4 text-sm">
                    <a href="/upload" class="text-slate-400 hover:text-white transition-colors">Subir PDF</a>
                    <a href="/denuncias" class="text-slate-400 hover:text-white transition-colors">Plantillas</a>
                    <a href="/informes" class="text-blue-400 font-medium">Informes Listos</a>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <span class="text-slate-400 text-sm hidden sm:inline">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <%= username %>
                </span>
                <form action="/logout" method="POST" class="inline">
                    <button type="submit" class="text-sm px-4 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-300 hover:bg-white/10 hover:text-white transition-all duration-200">
                        Salir
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 py-8">
        
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-white tracking-tight">Repositorio de Informes</h1>
            <p class="text-slate-400 mt-1 text-sm">Visualiza o descarga los documentos generados listos para revisión.</p>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 shadow-2xl">
            <% if (error) { %>
                <ul class="space-y-4 mb-4" id="serverErrorList">
                    <li class="group bg-red-900/30 hover:bg-red-900/40 border border-red-500/40 rounded-xl overflow-hidden transition-all duration-300 shadow-sm">
                        <div class="py-4 px-5 flex items-center justify-between">
                            <div class="flex items-center gap-4 min-w-0">
                                <div class="w-10 h-10 rounded-lg bg-red-500/20 border border-red-500/30 flex flex-shrink-0 items-center justify-center">
                                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                </div>
                                <div class="min-w-0 flex flex-col">
                                    <p class="text-red-300 font-bold text-sm tracking-wide">
                                        ERROR EN CARGA DE INFORMES
                                    </p>
                                    <p class="text-red-200 text-xs mt-0.5 leading-relaxed">
                                        Origen: Servidor <br>
                                        Detalle: <%= error %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </li>
                </ul>
            <% } %>

            <% if (archivos && archivos.length > 0) { %>
                <ul class="space-y-4">
                    <% archivos.forEach((archivo) => { %>
                        <li class="group bg-slate-800/50 hover:bg-slate-800 border border-white/10 hover:border-white/20 rounded-xl overflow-hidden transition-all duration-300 shadow-sm">
                            <div class="py-4 px-5 flex items-center justify-between">
                                <div class="flex items-center gap-4 min-w-0">
                                    <div class="w-10 h-10 rounded-lg bg-blue-500/10 border border-blue-500/20 flex flex-shrink-0 items-center justify-center">
                                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                        </svg>
                                    </div>
                                    <div class="min-w-0 flex flex-col">
                                        <p class="text-white font-medium text-sm truncate group-hover:text-blue-400 transition-colors">
                                            <%= archivo.name %>
                                        </p>
                                        <p class="text-slate-500 text-xs mt-0.5 flex items-center gap-2">
                                            <span><%= archivo.size %> KB</span>
                                            <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                                            <span><%= new Date(archivo.created).toLocaleDateString() %></span>
                                        </p>
                                    </div>
                                </div>
                                
                                <!-- Actions -->
                                <div class="flex items-center gap-2 pl-4">
                                    <a href="/informes/abrir/<%= encodeURIComponent(archivo.name) %>" target="_blank"
                                       class="px-3 py-1.5 text-xs font-medium text-blue-400 hover:text-white bg-blue-500/10 hover:bg-blue-500 border border-blue-500/20 hover:border-blue-500 rounded-lg transition-all duration-200"
                                       title="Abrir en nueva pestaña">
                                        Abrir
                                    </a>
                                    <a href="/informes/descargar/<%= encodeURIComponent(archivo.name) %>"
                                       class="p-1.5 text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 items-center rounded-lg transition-all duration-200"
                                       title="Descargar archivo">
                                       <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                       </svg>
                                    </a>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <div class="text-center py-12">
                    <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/5 flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                        </svg>
                    </div>
                    <h3 class="text-white font-medium">Bandeja Vacía</h3>
                    <p class="text-slate-400 text-sm mt-1">Aún no hay informes procesados listos para descargar.</p>
                </div>
            <% } %>
        </div>
    </main>
    <script>
        // Auto-refresh logic (Polling every 30 seconds)
        setInterval(() => {
            console.log('Auto-refreshing informes list...');
            location.reload();
        }, 30000);
    </script>
</body>
</html>
